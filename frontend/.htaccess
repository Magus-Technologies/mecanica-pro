Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /mecanica/

    # PRIMERO: no tocar nada que ya sea un archivo real
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # SEGUNDO: no reescribir la API (la maneja ProxyPass en conf.d)
    RewriteCond %{REQUEST_URI} !^/mecanica/api/

    # Portal cliente
    RewriteRule ^seguimiento/[a-zA-Z0-9]+$ seguimiento.html [L]

    # SPA fallback
    RewriteRule ^ index.html [L]
</IfModule>
