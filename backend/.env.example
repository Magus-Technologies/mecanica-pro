# ================================
# MecánicaPro - Variables de entorno
# Copiar como .env y configurar
# ================================

NODE_ENV=production
PORT=3001

# MySQL / MariaDB
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mecanica_pro
DB_USER=mecanica_user
DB_PASSWORD=TU_PASSWORD_SEGURA_AQUI

# JWT
JWT_SECRET=CAMBIA_ESTO_POR_UNA_CADENA_LARGA_Y_ALEATORIA_DE_AL_MENOS_64_CARACTERES
JWT_EXPIRES_IN=8h

# CORS
CORS_ORIGIN=https://magus-ecommerce.com

# Uploads
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
