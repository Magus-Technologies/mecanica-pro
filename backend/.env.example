# ================================
# MecánicaPro - Variables de entorno
# Copiar como .env y configurar
# ================================

NODE_ENV=production
PORT=3001

# MySQL / MariaDB
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mecanica_pro
DB_USER=mecanica_user
DB_PASSWORD=TU_PASSWORD_SEGURA_AQUI

# JWT
JWT_SECRET=CAMBIA_ESTO_POR_UNA_CADENA_LARGA_Y_ALEATORIA_DE_AL_MENOS_64_CARACTERES
JWT_EXPIRES_IN=8h

# CORS
CORS_ORIGIN=https://magus-ecommerce.com

# Uploads
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# ─── SUNAT (Facturación Electrónica) ────────────────────────────
SUNAT_API_URL=http://84.247.162.204/api-sunat-laravel/api/v1
SUNAT_API_TIMEOUT=60000
SUNAT_ENDPOINT=beta
SUNAT_RUC=20000000001
SUNAT_USUARIO_SOL=MODDATOS
SUNAT_CLAVE_SOL=MODDATOS
SUNAT_RAZON_SOCIAL=EMPRESA DE PRUEBAS S.A.C.
SUNAT_NOMBRE_COMERCIAL=MecánicaPro
SUNAT_DIRECCION=AV. PRUEBA 123
SUNAT_UBIGEO=150101
SUNAT_DISTRITO=LIMA
SUNAT_PROVINCIA=LIMA
SUNAT_DEPARTAMENTO=LIMA
SUNAT_SERIE_FACTURA=F001
SUNAT_SERIE_BOLETA=B001
